# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# FASHN.ai (virtual try-on)
FASHN_API_KEY=your_fashn_api_key

# Anthropic (AI colour analysis + trend agent)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Tavily (web search for trend agent — free tier: 1000 queries/month)
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key

# Cron secret (protects the /api/trends/refresh endpoint)
# Generate any random string, e.g: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
